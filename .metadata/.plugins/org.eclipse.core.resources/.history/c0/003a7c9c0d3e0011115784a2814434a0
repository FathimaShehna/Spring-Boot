package com.example.myapp.controllers;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.stereotype.Controller;


	@Controller
	public class HelloWorldController {
	
	    @GetMapping("/hello")    //url 
	    						//When a user accesses the "/hello" URL in the application, Spring Boot will call the hello() method in the HelloWorldController class
	    
	    public String hello() {
	        return "HelloWorld";    //HelloWorld in return statement is the name of the Html page
	    }
	}